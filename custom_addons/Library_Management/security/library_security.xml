<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Grupo: Bibliotecario (control total) -->
        <record id="group_library_manager" model="res.groups">
            <field name="name">Bibliotecario</field>
        </record>

        <!-- Grupo: Usuario Público (solo lectura de libros disponibles) -->
        <record id="group_library_user" model="res.groups">
            <field name="name">Usuario Público Biblioteca</field>
        </record>

        <!-- Regla: Usuario Público solo ve libros disponibles -->
        <record id="rule_library_book_public" model="ir.rule">
            <field name="name">Libros: solo disponibles para Usuario Público</field>
            <field name="model_id" ref="model_library_book"/>
            <field name="groups" eval="[(4, ref('group_library_user'))]"/>
            <field name="domain_force">[('is_available', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>