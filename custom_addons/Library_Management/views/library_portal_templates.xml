<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_library_loans" name="Mis Préstamos">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Mis Préstamos</t>
            </t>
            <table class="table table-hover">
                <thead>
                    <tr class="active">
                        <th>Libro</th>
                        <th>Fecha Préstamo</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="loans" t-as="loan">
                        <tr>
                            <td><t t-out="loan.book_id.name"/></td>
                            <td><t t-out="loan.loan_date"/></td>
                            <td><span t-field="loan.state" class="badge rounded-pill text-bg-info"/></td>
                            <td>
                                <a t-if="loan.state != 'overdue'" 
                                   t-attf-href="/my/library/renew/{{loan.id}}" 
                                   class="btn btn-sm btn-primary">Renovar</a>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </t>
    </template>
</odoo>