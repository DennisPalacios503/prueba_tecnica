<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_loan_list" model="ir.ui.view">
        <field name="name">library.loan.list</field>
        <field name="model">library.loan</field>
        <field name="arch" type="xml">
            <list string="Préstamos" decoration-danger="state == 'overdue'" decoration-success="state == 'returned'">
                <field name="book_id"/>
                <field name="member_id"/>
                <field name="loan_date"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'active'" 
                       decoration-warning="state == 'overdue'" 
                       decoration-success="state == 'returned'"/>
                <button name="action_return_book" string="Devolver" type="object" 
                        invisible="state == 'returned'" class="oe_highlight"/>
            </list>
        </field>
    </record>

    <record id="action_library_loan" model="ir.actions.act_window">
        <field name="name">Préstamos</field>
        <field name="res_model">library.loan</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_library_loans"
              name="Préstamos"
              parent="menu_library_root"
              action="action_library_loan"
              sequence="20"/>
</odoo>