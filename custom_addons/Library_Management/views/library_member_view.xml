<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_library_member_form" model="ir.ui.view">
        <field name="name">res.partner.library.member.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Biblioteca" name="library_info">
                    <group>
                        <field name="is_library_member" widget="boolean_toggle"/>
                    </group>
                    <group invisible="not is_library_member">
                        <field name="library_member_code" readonly="1"/>
                        <field name="library_membership_date" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>